{
  "name": "image-to-prompt-worker",
  "version": "1.0.0",
  "description": "Cloudflare Workers AI - Image to Prompt Generator",
  "main": "workers/prompt-worker.ts",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "type-check": "tsc --noEmit",
    "build:css": "postcss src/input.css -o output.css",
    "watch:css": "postcss src/input.css -o output.css --watch"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.2",
    "wrangler": "^3.93.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0"
  }
}
